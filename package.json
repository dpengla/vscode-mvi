{
  "name": "mvijs",
  "displayName": "MVI",
  "description": "VS Code extension with mvi-style modal controls.",
  "repository": "https://github.com/dpengla/vscode-mvi",
  "version": "0.0.1",
  "publisher": "depeng",
  "license": "MIT",
  "engines": {
    "vscode": "^1.85.0"
  },
  "keywords": [
    "vim",
    "modal",
    "editor",
    "mvi",
    "neovim"
  ],
  "categories": [
    "Other"
  ],
  "extensionKind": [
    "workspace"
  ],
  "capabilities": {
    "untrustedWorkspaces": {
      "supported": true
    }
  },
  "activationEvents": [
    "onStartupFinished",
    "onCommand:mvijs.enable",
    "onCommand:mvijs.disable"
  ],
  "main": "./extension.js",
  "scripts": {
    "check": "node --check extension.js"
  },
  "contributes": {
    "commands": [
      {
        "command": "mvijs.enable",
        "title": "MVI: Enable"
      },
      {
        "command": "mvijs.disable",
        "title": "MVI: Disable"
      },
      {
        "command": "mvijs.escape",
        "title": "MVI: Escape"
      },
      {
        "command": "mvijs.backspace",
        "title": "MVI: Backspace"
      },
      {
        "command": "mvijs.enter",
        "title": "MVI: Enter"
      },
      {
        "command": "mvijs.visualBlock",
        "title": "MVI: Visual Block"
      }
    ],
    "configuration": {
      "title": "MVI",
      "properties": {
        "mvijs.autoEnable": {
          "type": "boolean",
          "default": true,
          "description": "Enable MVI automatically when VS Code starts."
        }
      }
    },
    "keybindings": [
      {
        "command": "mvijs.escape",
        "key": "escape",
        "when": "editorTextFocus && mvijs.enabled"
      },
      {
        "command": "mvijs.escape",
        "key": "ctrl+[",
        "when": "editorTextFocus && mvijs.enabled"
      },
      {
        "command": "mvijs.backspace",
        "key": "backspace",
        "when": "editorTextFocus && mvijs.enabled"
      },
      {
        "command": "mvijs.enter",
        "key": "enter",
        "when": "editorTextFocus && mvijs.enabled && mvijs.exMode"
      },
      {
        "command": "mvijs.visualBlock",
        "key": "ctrl+v",
        "when": "editorTextFocus && mvijs.enabled"
      },
      {
        "command": "mvijs.visualBlock",
        "key": "cmd+v",
        "when": "isMac && editorTextFocus && mvijs.enabled"
      },
      {
        "command": "mvijs.visualBlock",
        "key": "ctrl+q",
        "when": "editorTextFocus && mvijs.enabled"
      }
    ]
  }
}
